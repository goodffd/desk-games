{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "noEmit": true,
    "skipLibCheck": true,
    "lib": ["ES2020", "DOM"],
    "types": ["vite/client"]
  },
  "include": ["src", "tests", "vite.config.ts", "vitest.slow.config.ts"],
  "exclude": ["src/games/xiangqi", "tests/xiangqi", "src/shell/registry.ts", "src/main.ts"]
}
